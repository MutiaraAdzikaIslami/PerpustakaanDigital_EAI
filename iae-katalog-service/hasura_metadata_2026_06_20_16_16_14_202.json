{
  "resource_version": 4,
  "metadata": {
    "version": 3,
    "sources": [
      {
        "name": "default",
        "kind": "postgres",
        "tables": [],
        "configuration": {
          "connection_info": {
            "database_url": {
              "from_env": "HASURA_GRAPHQL_DATABASE_URL"
            },
            "isolation_level": "read-committed",
            "pool_settings": {
              "connection_lifetime": 600,
              "idle_timeout": 180,
              "max_connections": 50,
              "retries": 1
            },
            "use_prepared_statements": true
          }
        }
      },
      {
        "name": "db_katalog",
        "kind": "postgres",
        "tables": [
          {
            "table": {
              "name": "books",
              "schema": "public"
            }
          }
        ],
        "configuration": {
          "connection_info": {
            "database_url": "postgres://postgresuser:postgrespassword@postgres_db:5432/db_katalog",
            "isolation_level": "read-committed",
            "use_prepared_statements": false
          }
        }
      }
    ]
  }
}